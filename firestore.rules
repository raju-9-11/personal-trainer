rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow users to read/write their own trainer profile
    match /trainers/{trainerId} {
      allow read: if true; // Publicly viewable
      allow write: if isSignedIn() && request.auth.uid == trainerId;
      
      // Sub-collections like brand_identity, certifications, etc.
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == trainerId;
      }
    }

    // Allow users to read/write their own AI trainer data (Encrypted)
    match /ai_trainers/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Therapy profiles
    match /therapist_profiles/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Platform settings (Admin only)
    match /platform_settings/{document=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.admin == true;
    }
  }
}